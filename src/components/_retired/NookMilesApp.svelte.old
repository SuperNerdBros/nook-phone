<script lang="ts">
  import nookState from '@/lib/nookState.svelte';
  import { Award, Check, Sparkles, Flame, PlusCircle } from '@lucide/svelte';

  let activeCategory: "Standard" | "Nook Miles+" = $state("Standard");
  let claimedId: string | null = $state(null);

  let challenges = $derived(nookState.milesChallenges.filter(c => c.category === activeCategory));

  function handleClaim(id: string) {
    const success = nookState.claimMilesReward(id);
    if (success) {
      claimedId = id;
      setTimeout(() => claimedId = null, 1500); // clear animation
    }
  }

  function handleCompleteDailyTaskMock(id: string) {
    nookState.triggerAchievementProgress(id, 1);
  }
</script>

<div id="miles-app" class="flex flex-col h-full ac-app-screen relative">
  <!-- Header -->
  <div class="bg-[#f0c354] text-[#4d3209] p-4 pt-6 ac-wavy-header flex justify-between items-end relative overflow-hidden z-10">
    <div>
      <h1 class="text-xl font-bold flex items-center gap-1.5">🗺️ Nook Miles</h1>
      <p class="text-xs opacity-90">Collect miles and exchange them for awards!</p>
    </div>

    <!-- Balance Display -->
    <div class="bg-white/95 px-3 py-1.5 rounded-2xl flex flex-col items-end border-2 border-[#caa253]/50 shadow-sm shrink-0">
      <span class="text-[9px] uppercase font-bold text-amber-800 tracking-wider">Current Balance</span>
      <span class="font-mono font-black text-amber-600 text-sm flex items-center gap-1">
        🎈 {nookState.miles.toLocaleString()} <span class="text-[10px] text-gray-500 font-bold">miles</span>
      </span>
    </div>
  </div>

  <!-- Tabs -->
  <div class="flex bg-[#fbf9f0] border-b border-[#e4dfd0] text-sm z-10">
    <button
      onclick={() => activeCategory = "Standard"}
      class="flex-1 py-3 font-bold text-center border-b-4 transition-all flex items-center justify-center gap-1.5 {
        activeCategory === 'Standard'
          ? 'border-[#f0c354] text-amber-700 bg-[#fbf9f0]'
          : 'border-transparent text-gray-400 hover:text-gray-600'
      }"
    >
      <Award class="w-4 h-4" /> Standard Miles
    </button>
    <button
      onclick={() => activeCategory = "Nook Miles+"}
      class="flex-1 py-3 font-bold text-center border-b-4 transition-all flex items-center justify-center gap-1.5 {
        activeCategory === 'Nook Miles+'
          ? 'border-[#ef4444] text-[#ef4444] bg-[#fff5f5]'
          : 'border-transparent text-gray-400 hover:text-gray-600'
      }"
    >
      <Flame class="w-4 h-4 text-[#ef4444] animate-pulse" /> Nook Miles+
    </button>
  </div>

  <!-- Challenge List -->
  <div class="flex-1 overflow-y-auto p-4 ac-scrollbar flex flex-col gap-4">
    {#if activeCategory === "Nook Miles+"}
      <div class="bg-[#fee2e2] text-red-900 rounded-2xl p-3 border border-red-200 text-xs flex flex-col gap-1 shadow-inner">
        <span class="font-bold flex items-center gap-1">🔥 Active Daily Goals:</span>
        <p class="opacity-95 leading-relaxed">
          These quick-hit tasks refresh immediately when completed. Complete them to fast-track your pocket miles!
        </p>
      </div>
    {/if}

    {#each challenges as c (c.id)}
      {@const progressPercent = Math.min(100, (c.progress / c.target) * 100)}
      {@const isComplete = c.progress >= c.target}

      <div
        class="rounded-3xl p-4 border relative overflow-hidden transition-all duration-300 {
          c.isClaimed
            ? 'bg-[#faf9f5] border-gray-200 opacity-75'
            : isComplete
            ? 'bg-gradient-to-br from-[#fefcf0] to-[#fffbc7] border-amber-300 shadow-md ring-2 ring-amber-300/30 scale-[1.01]'
            : 'bg-white border-[#edd8aa]/50 shadow-sm'
        }"
      >
        <div class="flex justify-between items-start gap-4">
          <div class="flex-1">
            <h3 class="font-extrabold text-sm text-[#4c4637] flex items-center gap-1.5">
              {c.title}
              {#if isComplete && !c.isClaimed}
                <span class="animate-ac-blink text-[10px] bg-emerald-100 text-emerald-800 font-bold px-2 py-0.5 rounded-full">
                  Ready to Claim!
                </span>
              {/if}
            </h3>
            <p class="text-xs text-gray-500 mt-1 leading-relaxed">
              {c.description}
            </p>
          </div>

          <!-- Stamp Icon -->
          <div
            class="w-12 h-12 rounded-full flex items-center justify-center ac-stamp {
              isComplete ? 'ac-stamp-completed' : ''
            } {c.isClaimed ? 'ac-stamp-claimed' : ''}"
          >
            {#if c.isClaimed}
              <Check class="w-6 h-6 text-emerald-600 stroke-[3px]" />
            {:else}
              <span class="text-[10px] font-extrabold text-[#caa253]">
                {c.reward}
              </span>
            {/if}
          </div>
        </div>

        <!-- Progress and Claim -->
        <div class="mt-4 pt-3 border-t border-[#fbf9f0] flex items-center justify-between gap-4">
          <div class="flex-1 flex items-center gap-2">
            <!-- Progress Bar -->
            <div class="flex-1 bg-gray-100 rounded-full h-2.5 overflow-hidden">
              <div
                class="h-full rounded-full transition-all duration-500 {
                  isComplete ? 'bg-emerald-500' : 'bg-amber-400'
                }"
                style="width: {progressPercent}%"
              ></div>
            </div>
            <span class="text-xs font-mono font-bold text-gray-500 shrink-0">
              {c.progress} / {c.target}
            </span>
          </div>

          <!-- Claim Button / Status -->
          {#if c.isClaimed}
            <span class="text-xs font-bold text-gray-400 flex items-center gap-1 bg-gray-50 px-2.5 py-1 rounded-full">
              <Check class="w-3.5 h-3.5" /> Claimed
            </span>
          {:else if isComplete}
            <button
              onclick={() => handleClaim(c.id)}
              class="bg-[#22c55e] text-white font-extrabold px-3 py-1.5 rounded-full text-xs hover:bg-[#16a34a] shadow-sm flex items-center gap-1 active:scale-95 transition-all"
            >
              Claim +{c.reward} m
            </button>
          {:else}
            <button
              onclick={() => handleCompleteDailyTaskMock(c.id)}
              class="text-[10px] font-bold text-gray-400 border border-gray-300 px-2.5 py-1 rounded-full hover:bg-gray-50 flex items-center gap-1.5"
              title="Simulate task progress"
            >
              <PlusCircle class="w-3 h-3" /> Do Task
            </button>
          {/if}
        </div>

        <!-- Sparkle explosion on claim -->
        {#if claimedId === c.id}
          <div class="absolute inset-0 bg-white/40 flex items-center justify-center z-50 animate-flash">
            <div class="flex flex-col items-center gap-1">
              <Sparkles class="w-12 h-12 text-yellow-500 animate-bounce" />
              <span class="font-bold text-amber-700 text-sm">Miles Claimed!</span>
            </div>
          </div>
        {/if}
      </div>
    {/each}
  </div>
</div>
